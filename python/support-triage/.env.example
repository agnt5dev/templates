# Optional: Enable real LLM for AI-generated replies
# By default, the demo uses mock responses (no API key needed)

# Set this to enable real LLM
# AGNT5_USE_REAL_LLM=1

# OpenAI API key (for GPT-4o-mini)
# OPENAI_API_KEY=sk-your-key-here

# OR Anthropic API key (for Claude)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# AGNT5 Platform settings (defaults work for local dev)
# AGNT5_COORDINATOR_ENDPOINT=http://localhost:34186
